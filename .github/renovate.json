{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeMinor",
    ":automergePr",
    ":automergeRequireAllStatusChecks",
    ":disableRateLimiting",
    ":semanticCommits"
  ],
  "dependencyDashboard": true,
  "schedule": [
    "* 14 * * 1,4"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "pep621",
        "pep723"
      ],
      "groupName": "Python dependencies"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions",
      "pinDigests": true
    },
    {
      "matchPackageNames": [
        "astral-sh/setup-uv"
      ],
      "matchManagers": [
        "github-actions"
      ],
      "versioning": "semver-coerced"
    },
    {
      "matchManagers": [
        "cargo"
      ],
      "groupName": "Rust dependencies"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "src/pyapp/\\.env\\.template$"
      ],
      "matchStrings": [
        "PYAPP_UV_VERSION\\s*=\\s*(?<currentValue>.*)"
      ],
      "depNameTemplate": "astral-sh/uv",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver",
      "groupName": "uv"
    }
  ]
}